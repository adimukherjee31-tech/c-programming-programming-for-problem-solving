#include <stdio.h>

/**
 * This program takes a decimal number (0-255) and 
 * displays its 8-bit binary equivalent.
 */
int main() {
    int num;
    int binary[8] = {0}; // Array to store 8 bits
    int i;

    // Prompt user for input
    printf("Enter a positive number between 0 and 255: ");
    if (scanf("%d", &num) != 1) {
        printf("Invalid input.\n");
        return 1;
    }

    // Validate if number is within the specified range
    if (num < 0 || num > 255) {
        printf("Error: Number is out of range.\n");
        return 1;
    }

    // Store original number for final output
    int originalNum = num;

    // Conversion logic: Repeatedly divide by 2 and store remainders
    for (i = 0; i < 8; i++) {
        binary[i] = num % 2;
        num = num / 2;
    }

    // Display the binary equivalent in reverse order
    printf("The binary equivalent of %d is: ", originalNum);
    for (i = 7; i >= 0; i--) {
        printf("%d", binary[i]);
    }
    printf("\n");

    return 0;
}
