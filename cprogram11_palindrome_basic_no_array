#include <stdio.h>

/**
 * Program to find the sum of individual digits and 
 * check if a number is a palindrome.
 */
int main() {
    int num, originalNum, remainder, sum = 0, reversedNum = 0;

    printf("Enter a positive integer: ");
    scanf("%d", &num);

    // Store original number to compare later
    originalNum = num;

    // Use a while loop to process each digit
    while (num > 0) {
        // Extract the last digit
        remainder = num % 10;

        // 1. Calculate sum of digits
        sum += remainder;

        // 2. Build the reversed number for palindrome check
        reversedNum = (reversedNum * 10) + remainder;

        // Remove the last digit from the number
        num /= 10;
    }

    printf("Sum of individual digits: %d\n", sum);

    // Check if the reversed number is equal to the original
    if (originalNum == reversedNum) {
        printf("%d is a palindrome.\n", originalNum);
    } else {
        printf("%d is not a palindrome.\n", originalNum);
    }

    return 0;
}
