/* reverse array elements using a pointer */
#include <stdio.h>

int main() {
    int n, i;
    int arr[100];
    int *ptr;

    // Input number of elements
    printf("Enter the number of elements in the array: ");
    scanf("%d", &n);

    // Input array elements
    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Set the pointer to the address of the last element
    ptr = &arr[n - 1];

    printf("\nElements in reverse order are:\n");

    // Loop through the array from last to first using the pointer
    for (i = 0; i < n; i++) {
        printf("%d ", *ptr); // Print value at current pointer address
        ptr--;               // Move pointer to the previous memory location
    }

    return 0;
}
