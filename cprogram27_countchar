#include <stdio.h>
#include <stdlib.h>

int main(int argc, char *argv[]) {
    // Check if correct number of arguments are provided
    if (argc != 3) {
        printf("Usage: %s <filename> <character>\n", argv[0]);
        return 1;
    }

    char *filename = argv[1];
    char target = argv[2][0]; // Take the first character of the second argument
    FILE *file = fopen(filename, "r");
    
    // Check if file exists
    if (file == NULL) {
        printf("Error: Could not open file %s\n", filename);
        return 1;
    }

    int count = 0;
    char ch;

    // Read file character by character until EOF
    while ((ch = fgetc(file)) != EOF) {
        if (ch == target) {
            count++;
        }
    }

    printf("The character '%c' occurs %d times in %s.\n", target, count, filename);

    fclose(file);
    return 0;
}

